# Claude Code ignore list (minimize context/tokens)
# Keep this focused on source code and lightweight config files.

# =========================
# Dependencies
# =========================
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn/cache/

# =========================
# Playwright artifacts
# =========================
artifacts/
test-results/
playwright-report/
blob-report/
playwright/.cache/
playwright/.auth/
playwright/videos/
playwright/screenshots/
trace/
*.trace

# =========================
# Local browser profiles
# =========================
profile*/
profiles/
artifacts/profiles/
user-data-dir/

# =========================
# Runner logs / outputs
# =========================
outputs/
logs/
*.log

# =========================
# Evidences / screenshots / media
# =========================
evidencias*/
screenshots/
videos/

# Images
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.bmp
*.tiff
*.svg

# Video
*.mp4
*.webm
*.mov
*.avi
*.mkv

# Documents / binary artifacts
*.pdf
*.xlsx
*.docx
*.pptx
*.csv

# =========================
